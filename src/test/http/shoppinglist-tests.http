### FOOD-12: Consume entire remaining amount — package should become empty
POST http://localhost:8080/api/foods/{{test_food_id}}/consume
Content-Type: application/json
Authorization: Bearer {{admin_token}}

{
  "useBy": "2026-07-15",
  "ml_g_left": 200
}

> {%
    client.test("Consume all: Status is 200", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("Consume all: Package is empty (remaining = -1, empty = true)", function() {
        client.assert(response.body.remaining_ml_g === -1,
            "remaining_ml_g should be -1 when empty");
        client.assert(response.body.empty === true, "empty flag should be true");
    });
%}


