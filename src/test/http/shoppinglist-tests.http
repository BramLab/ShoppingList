    });

    client.test("Admin get all users: Returns array with entries", function() {
        client.assert(Array.isArray(response.body),      "Response should be an array");
        client.assert(response.body.length > 0,          "Should have at least one user");
    });

    client.test("Admin get all users: User has correct structure", function() {
        const u = response.body[0];
        client.assert(u.id       !== undefined, "User should have id");
        client.assert(u.username !== undefined, "User should have username");
        client.assert(u.email    !== undefined, "User should have email");
        client.assert(u.role     !== undefined, "User should have role");
        client.assert(u.password === undefined, "User must not expose password");
    });

    client.log("✓ Admin retrieved " + response.body.length + " users");
%}

