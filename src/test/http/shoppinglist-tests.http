### STORED-SETUP: Create a fresh food item for stored-food tests
POST http://localhost:8080/api/foods
Content-Type: application/json
Authorization: Bearer {{admin_token}}

{
  "name": "Stored Test Kaas",
  "remarks": null,
  "bestBeforeEnd": "2026-10-01",
  "original_ml_g": 400
}

> {%
    client.global.set("stored_test_food_id", response.body.id);
    client.log("✓ Fresh food for stored-food tests: id=" + response.body.id);
%}

### STORED-1: Create a stored food entry — should return 201
POST http://localhost:8080/api/stored-foods
Content-Type: application/json
Authorization: Bearer {{admin_token}}

{
  "homeId":        {{admin_home_id}},
  "foodId":        {{stored_test_food_id}},
  "storageTypeId": {{test_storage_type_id}},
  "quantity":      3
}

> {%
    client.test("Create stored food: Status is 201", function() {
        client.assert(response.status === 201, "Expected 201, got " + response.status);
    });

    client.test("Create stored food: Returns correct entry", function() {
        client.assert(response.body.id                     !== undefined,              "id should be present");
        client.assert(response.body.quantity               === 3,                      "quantity should be 3");
        client.assert(response.body.home.id                === parseInt(client.global.get("admin_home_id")),   "homeId should match");
        client.assert(response.body.food.id                === parseInt(client.global.get("stored_test_food_id")), "foodId should match");
        client.assert(response.body.storageType.id         === parseInt(client.global.get("test_storage_type_id")), "storageTypeId should match");
    });

    client.global.set("test_stored_food_id", response.body.id);
    client.log("✓ StoredFood created id=" + response.body.id);
%}

