# ==================== SHOPPINGLIST API — AUTOMATED TEST SUITE ====================
# Run all tests sequentially or individually.
# Seed data (ConfigViaService) must be loaded before running:
#   user01 / hashed01? → ADMIN    → home "home01"
#   user02 / hashed02? → NORMAL   → home "home01-user02"
#   user03 / hashed03? → NORMAL   → home "home02"
# Results appear in the "Run" tool window.

# ==================== SETUP ====================

### SETUP: Clear globals from previous runs
GET http://localhost:8080/api/foods

> {%
    client.global.clear("admin_token");
    client.global.clear("normal_token");
    client.global.clear("test_user_id");
    client.global.clear("admin_home_id");
    client.global.clear("test_home_id");
    client.global.clear("test_storage_type_id");
    client.global.clear("test_food_id");
    client.global.clear("test_stored_food_id");
    client.log("=== ShoppingList Test Suite Started ===");
%}

# ====================================================================================
# AUTH TESTS
# ====================================================================================

### AUTH-1: Register a new user — should return 201
# @name auth_register
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "id": 0,
  "username": "test_user_{{$random.integer(1000, 9999)}}",
  "email": "test_{{$random.integer(1000, 9999)}}@example.com",
  "role": "NORMAL",
  "password": "testpass123",
  "homeName": "test_home_{{$random.integer(1000, 9999)}}"
}

> {%
    client.test("Register: Status is 201", function() {
        client.assert(response.status === 201, "Expected 201, got " + response.status);
    });

    client.test("Register: Response has id, username, email, role, homeId", function() {
        client.assert(response.body.id        !== undefined, "id should be present");
        client.assert(response.body.username  !== undefined, "username should be present");
        client.assert(response.body.email     !== undefined, "email should be present");
        client.assert(response.body.role      === "NORMAL",  "role should be NORMAL");
        client.assert(response.body.homeId    !== undefined, "homeId should be present");
    });

    client.test("Register: Password not returned", function() {
        client.assert(response.body.password       === undefined, "password must not be in response");
        client.assert(response.body.passwordHashed === undefined, "passwordHashed must not be in response");
    });

    client.global.set("test_user_id",   response.body.id);
    client.global.set("test_user_name", response.body.username);
    client.log("✓ Test user registered: " + response.body.username + " (id=" + response.body.id + ")");
%}

### AUTH-2: Register with duplicate username — should return 400
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "id": 0,
  "username": "user01",
  "email": "another_{{$random.integer(1000,9999)}}@example.com",
  "role": "NORMAL",
  "password": "testpass123",
  "homeName": "some home"
}

> {%
    client.test("Duplicate username: Status is 400", function() {
        client.assert(response.status === 400, "Expected 400, got " + response.status);
    });

    client.test("Duplicate username: Has error message", function() {
        client.assert(response.body.message === "Username already exists.",
            "Expected 'Username already exists.', got: " + response.body.message);
    });

    client.log("✓ Duplicate username correctly rejected");
%}

### AUTH-3: Register with missing homeName — should return 400
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "id": 0,
  "username": "no_home_user",
  "email": "nohome@example.com",
  "role": "NORMAL",
  "password": "testpass123",
  "homeName": ""
}

> {%
    client.test("Missing homeName: Status is 400", function() {
        client.assert(response.status === 400, "Expected 400, got " + response.status);
    });

    client.log("✓ Missing homeName correctly rejected");
%}

### AUTH-4: Login with valid credentials — should return 200 + JWT
# @name login_admin
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "username": "user01",
  "password": "hashed01?"
}

> {%
    client.test("Admin login: Status is 200", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });

    client.test("Admin login: Response has JWT token", function() {
        client.assert(response.body.token           !== undefined, "token should be present");
        client.assert(response.body.token.length    > 50,          "token should be a JWT string");
    });

    client.test("Admin login: Response has correct user fields", function() {
        client.assert(response.body.id       !== undefined, "id should be present");
        client.assert(response.body.username === "user01",  "username should be user01");
        client.assert(response.body.role     === "ADMIN",   "role should be ADMIN");
        client.assert(response.body.email    !== undefined, "email should be present");
    });

    client.global.set("admin_token",   response.body.token);
    client.global.set("admin_user_id", response.body.id);
    client.log("✓ Admin logged in (id=" + response.body.id + ")");
%}

### AUTH-5: Login as NORMAL user
# @name login_normal
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "username": "user02",
  "password": "hashed02?"
}

> {%
