        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });

    client.global.set("normal_token",   response.body.token);
    client.global.set("normal_user_id", response.body.id);
    client.log("✓ Normal user logged in (id=" + response.body.id + ")");
%}

