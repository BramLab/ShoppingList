# ====================================================================================
# FOOD TESTS
# ====================================================================================

### FOOD-1: Create a food item — should return 201
POST http://localhost:8080/api/foods
Content-Type: application/json
Authorization: Bearer {{admin_token}}

{
  "name": "Test Melk",
  "remarks": "for automated test",
  "bestBeforeEnd": "2026-12-31",
  "original_ml_g": 1000
}

> {%
    client.test("Create food: Status is 201", function() {
        client.assert(response.status === 201, "Expected 201, got " + response.status);
    });

    client.test("Create food: Returns created food", function() {
        client.assert(response.body.id              !== undefined, "id should be present");
        client.assert(response.body.name            === "Test Melk", "name should be 'Test Melk'");
        client.assert(response.body.original_ml_g   === 1000,     "original_ml_g should be 1000");
        client.assert(response.body.remaining_ml_g  === 1000,     "remaining_ml_g should equal original on creation");
        client.assert(response.body.useBy           === null,     "useBy should be null on a sealed package");
        client.assert(response.body.empty           === false,    "empty should be false on creation");
    });

    client.global.set("test_food_id", response.body.id);
    client.log("✓ Food created id=" + response.body.id);
%}

