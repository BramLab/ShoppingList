### FOOD-8: Open a sealed package — should set useBy and return 200
POST http://localhost:8080/api/foods/{{test_food_id}}/open
Content-Type: application/json
Authorization: Bearer {{admin_token}}

{
  "useBy": "2026-07-15",
  "initialConsumption": 50
}

> {%
    client.test("Open package: Status is 200", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });

    client.test("Open package: useBy is set", function() {
        client.assert(response.body.useBy !== null, "useBy should not be null after opening");
    });

    client.test("Open package: remaining decreased by initialConsumption", function() {
        client.assert(response.body.remaining_ml_g === 950,
            "remaining_ml_g should be 950 (1000 - 50), got: " + response.body.remaining_ml_g);
    });

    client.test("Open package: effectiveUseBy equals useBy", function() {
        client.assert(response.body.effectiveUseBy === response.body.useBy,
            "effectiveUseBy should equal useBy when useBy is set");
    });

    client.log("✓ Package opened, remaining_ml_g=" + response.body.remaining_ml_g);
%}

### FOOD-9: Open package with useBy after bestBeforeEnd — should return 400
POST http://localhost:8080/api/foods/{{test_food_id}}/open
Content-Type: application/json
Authorization: Bearer {{admin_token}}

{
  "useBy": "2099-01-01",
  "initialConsumption": 0
}

> {%
    client.test("useBy after bestBeforeEnd: Status is 400", function() {
        client.assert(response.status === 400, "Expected 400, got " + response.status);
    });

    client.log("✓ useBy after bestBeforeEnd correctly rejected");
%}

### FOOD-10: Consume from an opened package — should return 200
# ml_g_left = new remaining (not amount consumed)
# Package is at 950 ml after opening; record 200 ml left.
POST http://localhost:8080/api/foods/{{test_food_id}}/consume
Content-Type: application/json
Authorization: Bearer {{admin_token}}

{
  "useBy": "2026-07-15",
  "ml_g_left": 200
}

> {%
    client.test("Consume: Status is 200", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("Consume: remaining_ml_g set to ml_g_left", function() {
        client.assert(response.body.remaining_ml_g === 200,
            "remaining_ml_g should be 200, got: " + response.body.remaining_ml_g);
        client.assert(response.body.empty === false, "empty should still be false");
    });
%}

